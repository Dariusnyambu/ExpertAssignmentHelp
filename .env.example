# Supabase — use BASE URL only, NOT /rest/v1/
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# PesaPal
REACT_APP_PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
REACT_APP_PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret

# PayPal
REACT_APP_PAYPAL_CLIENT_ID=your-paypal-client-id

# M-Pesa (Safaricom Daraja API)
REACT_APP_MPESA_CONSUMER_KEY=your-daraja-consumer-key
REACT_APP_MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
